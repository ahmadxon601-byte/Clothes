{
    "version": 2,
    "builds": [
        {
            "src": "apps/backend/src/index.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "buildCommand": "bash vercel-build.sh",
                "distDir": "public"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "apps/backend/src/index.ts"
        },
        {
            "source": "/telegram/(.*)",
            "destination": "apps/backend/src/index.ts"
        },
        {
            "source": "/health",
            "destination": "apps/backend/src/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}