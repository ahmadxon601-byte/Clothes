# Copy this file to .env and fill in the values
# cp .env.production.example .env

# PostgreSQL
DATABASE_URL=postgresql://postgres:your_strong_password_here@db:5432/pos
POSTGRES_DB=pos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# Auth
JWT_SECRET=your_very_long_random_secret_here
NEXT_PUBLIC_TOKEN_STORAGE_KEY=admin_token

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_BOT_TOKEN=your_admin_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
ADMIN_TELEGRAM_WEBHOOK_SECRET=your_admin_webhook_secret_here
TELEGRAM_WEBAPP_URL=https://your-domain.com
URL=https://your-domain.com
