{
  "name": "clothes",
  "version": "0.1.0",
  "private": true,
  "description": "Marketplace WebApp + Telegram bot stack",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "lint": "npm run lint -w web",
    "build": "npm run build -w web",
    "test": "npm run test --workspaces",
    "dev:legacy:frontend": "npm run dev -w frontend",
    "dev:legacy:backend": "npm run dev -w @clothes/backend"
  }
}
