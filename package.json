{
  "name": "clothes",
  "version": "0.1.0",
  "private": true,
  "description": "Marketplace WebApp + Telegram bot stack",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "dev:backend": "node -e \"console.error('Backend vaqtincha bloklangan. Yangi backend tayyor bo`lganda bu scriptni qayta yoqing.'); process.exit(1)\"",
    "dev:backend:real": "npm run dev:real -w backend",
    "lint": "npm run lint -w backend",
    "build": "npm run build -w backend",
    "test": "npm run test --workspaces",
    "dev:legacy:frontend": "npm run dev -w frontend"
  }
}
