    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
