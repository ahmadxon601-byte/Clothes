{
  "name": "clothes",
  "version": "0.1.0",
  "private": true,
  "description": "Marketplace WebApp + Telegram bot stack",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "lint": "npm run lint --workspaces",
    "build": "npm run build -w apps/frontend && npm run build -w apps/backend && mkdir public && cp -r apps/frontend/dist/* public/",
    "test": "npm run test --workspaces"
  }
}