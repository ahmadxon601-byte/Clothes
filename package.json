    "build": "next build",
    "postbuild": "node scripts/fix-build-css.mjs",
    "start": "next start",
    "lint": "next lint",
    "bot:dev": "tsx scripts/telegram-polling.ts",
    "bot:admin:dev": "tsx scripts/admin-telegram-polling.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@twa-dev/sdk": "^8.0.2",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "grammy": "^1.40.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.13.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
